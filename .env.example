# Flask
FLASK_CONFIG=development
SECRET_KEY=change-me-to-random-64-char-hex-string

# Database (SQLite by default)
DATABASE_URL=sqlite:///instance/pass_manager.db

# Local fallback admin (created by scripts/seed_admin.py)
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=

# LDAP / Active Directory
# Leave empty to disable LDAP and use only local fallback admin
LDAP_SERVER=
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=DC=example,DC=com
LDAP_USER_DN=OU=Users
LDAP_BIND_DN=CN=svc-passmanager,OU=ServiceAccounts,DC=example,DC=com
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})

# AD group → role mapping
# Either short CN (matched case-insensitively as substring) or full DN
LDAP_GROUP_ADMIN=CN=pass-admin
LDAP_GROUP_LEAD=CN=pass-lead
LDAP_GROUP_USER=CN=pass-user
LDAP_GROUP_ADMIN_DN=
LDAP_GROUP_LEAD_DN=
LDAP_GROUP_USER_DN=

# Pagination
ITEMS_PER_PAGE=50

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
