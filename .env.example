# Flask
# Для локальной разработки оставьте development. Для production — обязательно production.
# ВАЖНО: с b000860 dev тоже требует валидные SECRET_KEY и ENCRYPTION_KEY
# (DEBUG больше не освобождает от prod-secrets проверки — только TESTING=True
# является легитимным bypass, и он доступен только pytest).
FLASK_CONFIG=development
# Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Сгенерируйте: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Обязательно для ВСЕХ окружений (dev включительно). Без него create_app упадёт
# с RuntimeError ещё на этапе запуска.
ENCRYPTION_KEY=

# Database (SQLite by default)
DATABASE_URL=sqlite:///instance/pass_manager.db

# Local fallback admin (created by scripts/seed_admin.py)
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=

# LDAP / Active Directory
# Leave empty to disable LDAP and use only local fallback admin
LDAP_SERVER=
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=DC=example,DC=com
LDAP_USER_DN=OU=Users
LDAP_BIND_DN=CN=svc-passmanager,OU=ServiceAccounts,DC=example,DC=com
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})

# AD group → role mapping
# Используется ТОЛЬКО exact-DN matching (LDAP_GROUP_*_DN).
# Короткие CN (LDAP_GROUP_ADMIN/LEAD/USER) оставлены для обратной совместимости, но не используются.
LDAP_GROUP_ADMIN=CN=pass-admin
LDAP_GROUP_LEAD=CN=pass-lead
LDAP_GROUP_USER=CN=pass-user
LDAP_GROUP_ADMIN_DN=
LDAP_GROUP_LEAD_DN=
LDAP_GROUP_USER_DN=

# Pagination
ITEMS_PER_PAGE=50

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
